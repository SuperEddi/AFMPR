{
  "name": "sistema-actas-asignacion",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "backend": "wrangler pages dev ./public --d1 DB=detalle_activos_tierras --compatibility-date=2024-03-01 --port 8788",
    "db:init": "wrangler d1 execute detalle_activos_tierras --local --file=./sql/schema.sql",
    "db:init:remote": "wrangler d1 execute detalle_activos_tierras --remote --file=./sql/schema.sql",
    "deploy": "npm run build && wrangler pages deploy ./dist"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240208.0",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.6",
    "wrangler": "^3.30.1"
  }
}
